# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — it will never be committed.

MONARCH_EMAIL=you@example.com
MONARCH_PASSWORD=yourpassword

# TOTP setup secret from Monarch's authenticator app setup
# (the long alphanumeric string shown when you add an authenticator app).
# Only needed if your Monarch account has 2FA enabled.
MONARCH_MFA_SECRET=

# Optional: override the fetch window start (YYYY-MM-DD). Without it the window is
# year-to-date (Jan 1 of the current year → today). Set this to pull a prior year
# or all history, e.g. MONARCH_START_DATE=2025-01-01
# MONARCH_START_DATE=
